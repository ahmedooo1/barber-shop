# ============================================================
# Barber Shop - Variables d'environnement
# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# Ne JAMAIS committer le fichier ".env" (déjà exclu via .gitignore).
# ============================================================

# URL publique du site une fois déployé (utilisée pour le SEO et les liens)
# En local : http://localhost:3000 - en production : https://barbershop.aaweb.fr
SITE_URL=https://barbershop.aaweb.fr

# --- Base de données MySQL (réservations et messages) ---
# Les tables sont créées automatiquement au premier démarrage.
# Option A : une seule URL de connexion (fournie par la plupart des hébergeurs) :
# MYSQL_URL=mysql://utilisateur:motdepasse@hote:3306/nom_base
# Option B : variables séparées (utilisées si MYSQL_URL n'est pas définie) :
# Configuration locale recommandée avec le Docker Compose fourni :
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=barber
MYSQL_PASSWORD=barberpass
MYSQL_DATABASE=barbershop
# Mettre à "true" si l'hébergeur MySQL exige une connexion chiffrée (cas fréquent
# des hébergeurs gratuits comme Aiven ou TiDB Serverless).
MYSQL_SSL=false

# --- Envoi d'e-mails (SMTP Gmail - gratuit, sans plafond artificiel) ---
# 1. Activez la validation en 2 étapes sur le compte Gmail qui recevra les notifs.
# 2. Créez un "mot de passe d'application" : https://myaccount.google.com/apppasswords
# 3. Renseignez ci-dessous l'adresse Gmail et le mot de passe d'application (16 caractères, sans espaces).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=quickserve76@gmail.com
SMTP_PASS=REMPLACER_PAR_LE_MOT_DE_PASSE_APPLICATION
NOTIFY_EMAIL=quickserve76@gmail.com

# --- Panneau d'administration (/admin) ---
ADMIN_USERNAME=admin
# Recommandé : générez un hash avec `npm run hash-password -- "VotreMotDePasse"`
# et collez le résultat ici (ADMIN_PASSWORD_HASH a priorité sur ADMIN_PASSWORD).
ADMIN_PASSWORD_HASH=
# Solution de repli simple (moins sécurisée) si vous ne voulez pas hasher :
ADMIN_PASSWORD=ChangeMoi123!

# Clé secrète pour signer les sessions admin (générez une longue chaîne aléatoire,
# ex: openssl rand -hex 32)
SESSION_SECRET=remplacer_par_une_longue_chaine_aleatoire_unique
